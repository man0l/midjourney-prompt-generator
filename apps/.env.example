# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Supabase (client-side React islands)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Strapi CMS (deployed on Railway/Render)
STRAPI_URL=https://your-strapi.railway.app
STRAPI_API_TOKEN=your-strapi-api-token

# OpenAI (used in browser via React island)
VITE_OPENAI_API_KEY=sk-...

# OpenAI (server-side — used by /api/improve for the Chrome extension)
OPENAI_API_KEY=sk-...
