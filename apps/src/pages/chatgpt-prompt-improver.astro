---
import Layout from '../layouts/Layout.astro';
import SimplePromptTool from '../components/SimplePromptTool';
import { improveForChatGPT } from '../utils/promptTransformers';

Astro.response.headers.set('Cache-Control', 's-maxage=300, stale-while-revalidate=3600');
---
<Layout
  title="Free ChatGPT Prompt Improver — Improve Any Prompt Instantly"
  description="Turn weak ChatGPT prompts into powerful ones. Free prompt improver and ChatGPT prompt improver — paste your prompt, get a better version instantly. No sign-up."
>
  <div id="root">
    <SimplePromptTool
      client:only="react"
      seoTitle="ChatGPT Prompt Improver"
      seoDescription="Improve any ChatGPT prompt instantly."
      inputPlaceholder="Paste your original prompt here..."
      buttonLabel="Improve ChatGPT Prompt"
      transform={improveForChatGPT}
    />
  </div>

  <div class="px-6 py-12 space-y-6">
    <div class="text-center space-y-3 py-4">
      <h1 class="text-4xl font-bold text-[#1a1a1a]">ChatGPT Prompt Improver</h1>
      <p class="text-[#6b6559] text-base max-w-2xl mx-auto">
        Turn your existing ChatGPT prompt into a more powerful version. Our free prompt improver adds structure, context, and precision so you get the best result from ChatGPT every single time.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="border border-[#c8c0a8] rounded-xl p-6">
        <h3 class="text-lg font-bold text-[#1a1a1a] mb-3">What Does a Prompt Improver Do?</h3>
        <p class="text-[#6b6559] text-sm leading-relaxed">
          A ChatGPT prompt improver takes your original prompt and rewrites it with strategic structure, precise instructions, essential context, and output formatting. The difference: basic prompts get generic answers; improved prompts get exactly what you envisioned. This free chatgpt prompt improver works instantly — no account needed.
        </p>
      </div>
      <div class="border border-[#c8c0a8] rounded-xl p-6">
        <h3 class="text-lg font-bold text-[#1a1a1a] mb-4">Why Improve Your Prompts?</h3>
        <div class="space-y-3">
          <div class="flex items-start gap-2"><span class="mt-0.5">✅</span><p class="text-[#6b6559] text-sm">Get specific, detailed responses instead of vague answers</p></div>
          <div class="flex items-start gap-2"><span class="mt-0.5">✅</span><p class="text-[#6b6559] text-sm">Save time by getting it right the first time</p></div>
          <div class="flex items-start gap-2"><span class="mt-0.5">✅</span><p class="text-[#6b6559] text-sm">Works for any type of prompt — writing, coding, analysis, brainstorming</p></div>
          <div class="flex items-start gap-2"><span class="mt-0.5">✅</span><p class="text-[#6b6559] text-sm">Free prompt improver, no sign-up required</p></div>
        </div>
      </div>
    </div>

    <div class="border border-[#c8c0a8] rounded-xl p-6">
      <h3 class="text-lg font-bold text-[#1a1a1a] mb-4">Frequently Asked Questions</h3>
      <div class="space-y-4">
        <div>
          <p class="font-semibold text-[#1a1a1a] text-sm">Is this ChatGPT prompt improver free?</p>
          <p class="text-[#6b6559] text-xs mt-1">Yes — completely free, no sign-up required. Use it as many times as you need.</p>
        </div>
        <div>
          <p class="font-semibold text-[#1a1a1a] text-sm">What kinds of prompts can I improve?</p>
          <p class="text-[#6b6559] text-xs mt-1">Any prompt — writing, coding, analysis, creative tasks, research, brainstorming. The prompt improver adds structure and clarity that works across all use cases.</p>
        </div>
        <div>
          <p class="font-semibold text-[#1a1a1a] text-sm">Does it work with ChatGPT-4o and ChatGPT-5?</p>
          <p class="text-[#6b6559] text-xs mt-1">Yes. Improved prompts work with all ChatGPT versions, as well as Claude, Gemini, and other AI models.</p>
        </div>
      </div>
    </div>

    <a href="#root" class="block w-full py-4 bg-[#f0b429] border-2 border-[#1c1c1c] rounded-xl text-center font-bold text-[#1a1a1a] text-lg hover:brightness-95 transition-all">
      Improve Your Prompt Now
    </a>
  </div>
</Layout>
