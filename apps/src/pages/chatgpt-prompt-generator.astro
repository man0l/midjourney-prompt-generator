---
import Layout from '../layouts/Layout.astro';
import SimplePromptTool from '../components/SimplePromptTool';
import { generateChatGPTPrompt } from '../utils/promptTransformers';

Astro.response.headers.set('Cache-Control', 's-maxage=300, stale-while-revalidate=3600');
---
<Layout
  title="Free ChatGPT Prompt Generator — Generate ChatGPT Prompts Instantly"
  description="Generate expert ChatGPT prompts from any topic or task. Free ChatGPT prompt generator — create free ChatGPT prompts, free chatgpt prompts for any use case. No sign-up."
>
  <div id="root">
    <SimplePromptTool
      client:only="react"
      seoTitle="ChatGPT Prompt Generator"
      seoDescription="Generate expert ChatGPT prompts from any topic or task description."
      inputPlaceholder="Describe what you want ChatGPT to help you with... e.g. write a professional email declining a job offer, or explain machine learning to a 10-year-old"
      buttonLabel="Generate ChatGPT Prompt"
      transform={generateChatGPTPrompt}
    />
  </div>

  <div class="px-6 py-12 space-y-6">
    <div class="text-center space-y-3 py-4">
      <!-- BUILD_MARKER_v2 -->
      <h1 class="text-4xl font-bold text-[#1a1a1a]">ChatGPT Prompt Generator</h1>
      <p class="text-[#6b6559] text-base max-w-2xl mx-auto">
        Transform your simple ideas into expertly crafted ChatGPT prompts that deliver mind-blowing results. Our free ChatGPT prompt generator creates structured, context-rich prompts from plain descriptions — so you get precise, detailed answers instead of generic responses.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="border border-[#c8c0a8] rounded-xl p-6">
        <h3 class="text-lg font-bold text-[#1a1a1a] mb-3">What Is a ChatGPT Prompt Generator?</h3>
        <p class="text-[#6b6559] text-sm leading-relaxed">
          A ChatGPT prompt generator takes your basic request and turns it into an expert-level ChatGPT prompt. Free ChatGPT prompts from this tool include role framing, goal definition, format requirements, and tone — giving ChatGPT everything it needs to produce exactly what you want. Use it as a prompt generator chatgpt tool or a chat gpt prompt generator free of charge.
        </p>
      </div>
      <div class="border border-[#c8c0a8] rounded-xl p-6">
        <h3 class="text-lg font-bold text-[#1a1a1a] mb-4">Free ChatGPT Prompts for Every Use Case</h3>
        <div class="grid grid-cols-2 gap-x-4 gap-y-3">
          <div class="flex items-start gap-2"><span class="mt-0.5">✍️</span><p class="text-[#6b6559] text-sm">Writing & Content</p></div>
          <div class="flex items-start gap-2"><span class="mt-0.5">💻</span><p class="text-[#6b6559] text-sm">Coding & Development</p></div>
          <div class="flex items-start gap-2"><span class="mt-0.5">📊</span><p class="text-[#6b6559] text-sm">Analysis & Research</p></div>
          <div class="flex items-start gap-2"><span class="mt-0.5">🎓</span><p class="text-[#6b6559] text-sm">Learning & Explanation</p></div>
          <div class="flex items-start gap-2"><span class="mt-0.5">💼</span><p class="text-[#6b6559] text-sm">Business & Marketing</p></div>
          <div class="flex items-start gap-2"><span class="mt-0.5">🎨</span><p class="text-[#6b6559] text-sm">Creative & Brainstorming</p></div>
        </div>
      </div>
    </div>

    <div class="border border-[#c8c0a8] rounded-xl p-6">
      <h3 class="text-lg font-bold text-[#1a1a1a] mb-4">Frequently Asked Questions</h3>
      <div class="space-y-4">
        <div>
          <p class="font-semibold text-[#1a1a1a] text-sm">Is this ChatGPT prompt generator free?</p>
          <p class="text-[#6b6559] text-xs mt-1">Yes — free chatgpt prompts, no sign-up, no limits. Generate as many as you need.</p>
        </div>
        <div>
          <p class="font-semibold text-[#1a1a1a] text-sm">How do I create a prompt for ChatGPT?</p>
          <p class="text-[#6b6559] text-xs mt-1">Describe what you want in plain language — who should answer, what the task is, and what format you want the response in. This tool structures all of that automatically. It's the easiest way to learn how to create a prompt for ChatGPT.</p>
        </div>
        <div>
          <p class="font-semibold text-[#1a1a1a] text-sm">Are these chatgpt free prompts ready to use?</p>
          <p class="text-[#6b6559] text-xs mt-1">Yes — copy the generated prompt and paste it directly into ChatGPT. You can also edit it before using. Works with GPT-4o, ChatGPT-5, Claude, and Gemini.</p>
        </div>
      </div>
    </div>

    <div class="text-center text-xs text-[#6b6559] pb-2">
      Also try: <a href="/claude-prompt-generator" class="text-[#1a1a1a] underline hover:no-underline">Claude Prompt Generator</a> · <a href="/gemini-prompt-generator" class="text-[#1a1a1a] underline hover:no-underline">Gemini Prompt Generator</a>
    </div>

    <a href="#root" class="block w-full py-4 bg-[#f0b429] border-2 border-[#1c1c1c] rounded-xl text-center font-bold text-[#1a1a1a] text-lg hover:brightness-95 transition-all">
      Generate Your ChatGPT Prompt
    </a>
  </div>
</Layout>
