---
import Layout from '../layouts/Layout.astro';
import SimplePromptTool from '../components/SimplePromptTool';
import { generateLovablePrompt } from '../utils/promptTransformers';

Astro.response.headers.set('Cache-Control', 's-maxage=300, stale-while-revalidate=3600');
---
<Layout
  title="Free Lovable Prompt Generator — Build Full Apps with Lovable"
  description="Generate perfectly crafted Lovable prompts from your app idea. Free lovable prompt generator for lovable prompts that build complete, functional apps. No sign-up."
>
  <div id="root">
    <SimplePromptTool
      client:only="react"
      seoTitle="Lovable Prompt Generator"
      seoDescription="Generate Lovable prompts that build complete apps."
      inputPlaceholder="Describe your app idea... e.g. a project management tool for freelancers with task tracking and invoicing"
      buttonLabel="Generate Lovable Prompt"
      transform={generateLovablePrompt}
    />
  </div>

  <div class="px-6 py-12 space-y-6">
    <div class="text-center space-y-3 py-4">
      <h2 class="text-4xl font-bold text-[#1a1a1a]">Lovable Prompt Generator</h2>
      <p class="text-[#6b6559] text-base max-w-2xl mx-auto">
        Turn your app ideas into perfectly crafted lovable prompts that generate fully-functional applications with minimal debugging. Our free lovable prompt generator adds architecture specs, design standards, and technical requirements that Lovable needs to build production-ready apps.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="border border-[#c8c0a8] rounded-xl p-6">
        <h3 class="text-lg font-bold text-[#1a1a1a] mb-3">Why Use a Lovable Prompt Generator?</h3>
        <p class="text-[#6b6559] text-sm leading-relaxed">
          Lovable prompts that work aren't just descriptions — they're structured specifications. Our lovable prompt generator automatically adds React + TypeScript requirements, Tailwind/shadcn/ui design standards, accessibility rules, and quality constraints that turn your simple idea into a prompt Lovable can build completely and correctly.
        </p>
      </div>
      <div class="border border-[#c8c0a8] rounded-xl p-6">
        <h3 class="text-lg font-bold text-[#1a1a1a] mb-4">What Gets Added to Your Lovable Prompts</h3>
        <div class="space-y-3">
          <div class="flex items-start gap-2"><span class="mt-0.5">🏗️</span><p class="text-[#6b6559] text-sm">Architecture: React, TypeScript, component structure</p></div>
          <div class="flex items-start gap-2"><span class="mt-0.5">🎨</span><p class="text-[#6b6559] text-sm">Design: Tailwind CSS, shadcn/ui, responsive layout</p></div>
          <div class="flex items-start gap-2"><span class="mt-0.5">✅</span><p class="text-[#6b6559] text-sm">Quality: No placeholder code, production-ready standards</p></div>
          <div class="flex items-start gap-2"><span class="mt-0.5">♿</span><p class="text-[#6b6559] text-sm">Accessibility: ARIA labels, keyboard navigation</p></div>
        </div>
      </div>
    </div>

    <div class="border border-[#c8c0a8] rounded-xl p-6">
      <h3 class="text-lg font-bold text-[#1a1a1a] mb-4">Frequently Asked Questions</h3>
      <div class="space-y-4">
        <div>
          <p class="font-semibold text-[#1a1a1a] text-sm">Is this Lovable prompt generator free?</p>
          <p class="text-[#6b6559] text-xs mt-1">Yes — free, no sign-up. Generate as many lovable prompts as you need.</p>
        </div>
        <div>
          <p class="font-semibold text-[#1a1a1a] text-sm">What makes a good Lovable prompt?</p>
          <p class="text-[#6b6559] text-xs mt-1">Lovable prompts need to specify tech stack, design system, feature list, and quality standards. Our generator adds all of these automatically from your plain-language description.</p>
        </div>
        <div>
          <p class="font-semibold text-[#1a1a1a] text-sm">Can I edit the generated Lovable prompt?</p>
          <p class="text-[#6b6559] text-xs mt-1">Yes — copy the result and tweak it before pasting into Lovable. Add specific features, change the tech stack, or adjust the design requirements.</p>
        </div>
      </div>
    </div>

    <a href="#root" class="block w-full py-4 bg-[#f0b429] border-2 border-[#1c1c1c] rounded-xl text-center font-bold text-[#1a1a1a] text-lg hover:brightness-95 transition-all">
      Generate Your Lovable Prompt
    </a>
  </div>
</Layout>
